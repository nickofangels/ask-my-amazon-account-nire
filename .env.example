# ── SP-API Credentials ────────────────────────────────────────────────────
# Get these from Seller Central > Apps & Services > Develop Apps
SP_API_CLIENT_ID=amzn1.application-oa2-client.XXXX
SP_API_CLIENT_SECRET=amzn1.oa2-cs.v1.XXXX
SP_API_REFRESH_TOKEN=Atzr|XXXX

# ── Marketplace ───────────────────────────────────────────────────────────
SP_API_MARKETPLACE_ID_US=ATVPDKIKX0DER
SP_API_SELLER_ID=AXXXXXXXXXXXXX

# ── ASINs ─────────────────────────────────────────────────────────────────
# Comma-separated list of ASINs to track in SQP (Search Query Performance).
# These must be brand-registered ASINs on your seller account.
SQP_ASINS=B01XXXXXXX,B02XXXXXXX,B03XXXXXXX

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# ── Brand Keyword Classification ──────────────────────────────────────────
# These drive the scoring pipeline's keyword classification.
# Change these when porting to a new brand.
#
# BRANDED_TERMS: Phrases that identify YOUR brand (substring match)
BRANDED_TERMS=your brand name,your brand short
# BRANDED_EXACT: Exact single-word matches for your brand
BRANDED_EXACT=yourbrand
# BRANDED_COMBOS: Words that together mean your brand (pipe-separated groups, + between terms)
#   e.g. "death+coffee" matches "death wish coffee", "coffee of death", etc.
BRANDED_COMBOS=your+brand
# COMPETITOR_TERMS: Competitor brand names (substring match)
COMPETITOR_TERMS=competitor one,competitor two,competitor three
